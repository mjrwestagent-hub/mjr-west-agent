# ── Security ──────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ── Twilio / WhatsApp ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Comma-separated list of numbers to receive broadcast briefings
WA_BROADCAST_LIST=+61412345678,+61498765432

# ── Gmail IMAP ────────────────────────────────────────────────
GMAIL_USER=youraddress@gmail.com
# Generate at: myaccount.google.com → Security → App Passwords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Briefing Schedule ─────────────────────────────────────────
BRIEFING_HOUR=8
BRIEFING_MINUTE=0
TIMEZONE=Australia/Melbourne

# ── App ───────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false
UPLOAD_FOLDER=uploads

# Public-facing base URL (no trailing slash). Set to your custom domain once deployed.
# Leave blank in local dev — Flask derives it from the inbound request.
APP_URL=
